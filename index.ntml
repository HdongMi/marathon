  <!-- ══ Tab Bar ══ -->
  <div class="tab-bar">
    <button class="tab-btn active" id="tab-list" onclick="switchTab('list')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      대회목록
    </button>
    <button class="tab-btn" id="tab-calendar" onclick="switchTab('calendar')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      캘린더
    </button>
    <button class="tab-btn" id="tab-my" onclick="switchTab('my')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      마이
    </button>
  </div>
</div>

<script>
  // ── Tab switching ──
  const screens = { list: 'screen-list', calendar: 'screen-calendar', my: 'screen-my' };
  let currentTab = 'list';

  function switchTab(tab) {
    document.getElementById('screen-' + currentTab).classList.remove('active');
    document.getElementById('tab-' + currentTab).classList.remove('active');
    document.getElementById('screen-detail').classList.remove('active');

    currentTab = tab;
    document.getElementById('screen-' + tab).classList.add('active');
    document.getElementById('tab-' + tab).classList.add('active');
  }

  function showDetail() {
    document.getElementById('screen-list').classList.remove('active');
    document.getElementById('screen-calendar').classList.remove('active');
    document.getElementById('screen-detail').classList.add('active');
    // hide tabs
    document.querySelector('.tab-bar').style.display = 'none';
  }

  function showList() {
    document.getElementById('screen-detail').classList.remove('active');
    document.getElementById('screen-' + currentTab).classList.add('active');
    document.querySelector('.tab-bar').style.display = 'flex';
  }

  // ── Wishlist toggle ──
  let wished = false;
  function toggleWish() {
    wished = !wished;
    const icon = document.getElementById('wishIcon');
    icon.setAttribute('fill', wished ? '#ff4d2e' : 'none');
    icon.setAttribute('stroke', wished ? '#ff4d2e' : 'white');
  }

  // ── Calendar ──
  function buildCalendar() {
    const grid = document.getElementById('calGrid');
    const dows = ['일','월','화','수','목','금','토'];
    const raceDays = [3, 5, 6, 12, 19, 25];
    const redDays = [5, 19];

    dows.forEach(d => {
      const el = document.createElement('div');
      el.className = 'cal-dow';
      el.textContent = d;
      grid.appendChild(el);
    });

    // April 2026 starts on Wednesday (index 3)
    for (let i = 0; i < 3; i++) {
      const el = document.createElement('div');
      el.className = 'cal-day';
      grid.appendChild(el);
    }

    for (let d = 1; d <= 30; d++) {
      const el = document.createElement('div');
      el.className = 'cal-day current-month';
      if (d === 3) el.classList.add('today');
      el.innerHTML = d;
      if (raceDays.includes(d)) {
        const dot = document.createElement('div');
        dot.className = 'race-dot' + (redDays.includes(d) ? ' red' : '');
        el.appendChild(dot);
      }
      grid.appendChild(el);
    }
  }

  buildCalendar();

  // ── Chip filter ──
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
    });
  });

  // ── Course tabs ──
  document.querySelectorAll('.course-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.course-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
    });
  });
</script>
</body>
</html>
